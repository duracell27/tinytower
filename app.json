{
  "expo": {
    "name": "Tiny Tower",
    "slug": "tinytower",
    "scheme": "tinytower",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/logoBlack.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.duracell27.tinytower-init",
      "buildNumber": "1",
      "icon": {
        "light": "./assets/img/logoWhite.png",
        "dark": "./assets/img/logoBlack.png",
        "tinted": "./assets/img/logoBlack.png"
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/img/logoBlack.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.duracell27.tinytowerinit"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image",
      "expo-font",
      "expo-router",
      "expo-localization"
    ]
  }
}
